{
  "name": "claudio",
  "version": "0.3.0",
  "description": "电脑端本地个人 AI 电台",
  "type": "module",
  "main": "apps/server/dist/main.js",
  "scripts": {
    "start": "npm run build && npm run start:server",
    "start:compiled": "npm run start:server",
    "start:server": "node apps/server/dist/main.js",
    "dev:server": "npm run build:server && node --watch apps/server/dist/main.js",
    "dev:web": "vite --config apps/web/vite.config.ts --host 127.0.0.1 --port 5173",
    "build": "npm run build:core && npm run build:server && npm run build:web",
    "build:shared": "tsc -p packages/shared/tsconfig.json",
    "build:core": "npm run build:shared && tsc -p packages/core/tsconfig.json",
    "build:server": "npm run build:core && tsc -p apps/server/tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "test:core": "npm run build:core && node scripts/test-core.mjs",
    "typecheck:mobile": "tsc -p apps/mobile/tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:init": "node scripts/init-db.js",
    "db:import-v1": "node scripts/import-v1-data.js"
  },
  "keywords": [
    "ai-radio",
    "deepseek",
    "netease-cloud-music"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/send": "^4.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "fast-json-stringify": "^6.4.0",
    "fastify": "^5.8.5",
    "music-metadata": "^11.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "toad-cache": "^3.7.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
