{
  "name": "claudio",
  "version": "0.2.0",
  "description": "电脑端本地个人 AI 电台",
  "type": "module",
  "main": "apps/server/dist/index.js",
  "scripts": {
    "start": "node apps/server/dist/index.js",
    "start:legacy": "node server.js",
    "dev:server": "npm run build:server && node --watch apps/server/dist/index.js",
    "dev:web": "vite --host 127.0.0.1 --port 5173 apps/web",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p apps/server/tsconfig.json",
    "build:web": "vite build apps/web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai-radio",
    "deepseek",
    "netease-cloud-music"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
