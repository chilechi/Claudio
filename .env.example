# Claudio 本地运行配置

# 服务端口。8080 被占用时改成 8090 / 18110 等未占用端口。
PORT=8080

# SQLite 数据库路径。
DATABASE_PATH=data/claudio.sqlite

# 真实音乐源：优先先填这个，本地目录最稳定，可直接播放 mp3/flac/wav/m4a/aac/ogg/opus。
# MUSIC_SOURCE 可选：auto / local / netease。
# auto：有本地可播放音频时优先本地，否则使用网易云歌单元数据。
# local：只使用本地音乐目录。
# netease：使用网易云歌单元数据；当前不保证能直接播放。
MUSIC_SOURCE=auto
LOCAL_MUSIC_DIR=

# 网易云歌单元数据。当前用于读取歌单元数据，不承诺所有歌曲都可直接播放。
NETEASE_PLAYLIST_ID=
NETEASE_COOKIE=
NETEASE_API_BASE_URL=

# AI DJ。没有 DEEPSEEK_API_KEY 时会回退到本地规则脑。
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 语音输出。未配置时使用浏览器 TTS 回退。
TTS_PROVIDER=
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
EDGE_TTS_VOICE=
OPENAI_API_KEY=
OPENAI_TTS_MODEL=

# 语音输入。未配置时使用浏览器语音识别能力。
ASR_PROVIDER=
WHISPER_API_KEY=

# 天气。未配置时诊断页显示 missing。
WEATHER_PROVIDER=openweather
OPENWEATHER_API_KEY=
WEATHER_CITY=

# 日历/日程。v0.2 暂未接入 provider，先留空。
CALENDAR_PROVIDER=

# 家庭音响/UPnP。需要真实设备名后再启用。
UPNP_ENABLED=false
UPNP_DEVICE_NAME=
