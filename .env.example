# Claudio 本地运行配置

# 服务端口。8080 被占用时可改成 8090 / 18110 等未占用端口。
PORT=8080

# 音乐源。
# auto：有本地可播放音频时优先本地，否则使用网易云歌单元数据。
# local：只使用本地音乐目录。
# netease：使用网易云歌单元数据；当前不保证能直接播放。
MUSIC_SOURCE=auto
LOCAL_MUSIC_DIR=

# 网易云歌单元数据。只用于读取歌单信息，不承诺直接播放网易云音频。
NETEASE_PLAYLIST_ID=
NETEASE_COOKIE=
NETEASE_API_BASE_URL=

# AI DJ。没有 DEEPSEEK_API_KEY 时会回退到本地规则脑。
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 电台旁白语音输出。
# 不配置时，前端会使用浏览器 speechSynthesis 回退。
# Fish Audio 需要同时配置 TTS_PROVIDER、FISH_AUDIO_API_KEY、FISH_AUDIO_VOICE_ID。
TTS_PROVIDER=
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_BASE_URL=https://api.fish.audio
