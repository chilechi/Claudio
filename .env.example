# Claudio 本地运行配置

# 服务端口。8080 被占用时可改成 8090 / 18110 等未占用端口。
PORT=8080

# 音乐源。
# auto：有本地可播放音频时优先本地，否则使用网易云歌单元数据。
# local：只使用本地音乐目录。
# netease：使用网易云歌单元数据；当前不保证能直接播放。
MUSIC_SOURCE=auto
LOCAL_MUSIC_DIR=

# 网易云歌单元数据。只用于读取歌单信息，不承诺直接播放网易云音频。
NETEASE_PLAYLIST_ID=
NETEASE_COOKIE=
NETEASE_API_BASE_URL=

# AI DJ。没有 DEEPSEEK_API_KEY 时会回退到本地规则脑。
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 电台旁白语音输出。
# 不配置时，前端会使用浏览器 speechSynthesis 回退。
# Edge TTS 只需配置 TTS_PROVIDER=edge，无需 API Key。
# EDGE_TTS_VOICE 可选，默认 zh-CN-XiaoxiaoNeural（晓晓，女声）。
# 其他常用语音：zh-CN-YunxiNeural（云希，男声）、zh-CN-XiaoyiNeural（晓伊，女声）。
TTS_PROVIDER=edge
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
